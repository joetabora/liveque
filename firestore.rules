rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Queue collection: public read for display, authenticated write for admin
    match /queue/{document=**} {
      allow read: if true;
      // For production, restrict writes to authenticated users:
      // allow write: if request.auth != null;
      // For development, allow all writes:
      allow write: if true;
    }
  }
}
